---
interface Props {
  type?: 'info' | 'tip' | 'warn';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const styles = {
  info: 'border-emerald-500/60 bg-emerald-500/10 text-emerald-100',
  tip: 'border-sky-500/60 bg-sky-500/10 text-sky-100',
  warn: 'border-amber-500/60 bg-amber-500/10 text-amber-100',
} as const;

const labels = {
  info: 'Info',
  tip: 'Tip',
  warn: 'Warning',
} as const;
---

<aside
  class:list={[
    'not-prose my-6 rounded border-l-4 px-4 py-3 font-mono text-sm leading-relaxed',
    styles[type],
  ]}
  role="note"
>
  <p class="mb-1 text-xs font-bold uppercase tracking-wider opacity-80">
    {title ?? labels[type]}
  </p>
  <div class="text-zinc-200 [&_a]:text-emerald-400 [&_a]:underline [&_p]:m-0">
    <slot />
  </div>
</aside>
