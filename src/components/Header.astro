---
import Search from './Search.astro';
---
<header
  class="py-6 border-b border-zinc-800 flex justify-between items-center w-full gap-4"
  data-pagefind-ignore
>
  <a
    href="/"
    class="flex items-center gap-3 text-xl font-bold tracking-wider text-emerald-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 p-1 rounded"
  >
    <img
      src="/logo.png"
      alt="Allister Antosik logo"
      width="36"
      height="36"
      class="h-9 w-9 rounded-lg border border-zinc-800 bg-zinc-950 object-cover shadow-sm shadow-emerald-500/20"
    />
    <span class="hidden sm:inline">&gt;_ ALLISTER ANTOSIK</span>
    <span class="sm:hidden" aria-hidden="true">&gt;_ AA</span>
  </a>
  <div class="flex flex-1 items-center justify-end gap-3 sm:gap-4 min-w-0">
    <div class="flex min-w-0 flex-1 justify-end sm:max-w-md lg:max-w-lg">
      <Search />
    </div>
    <nav class="flex shrink-0 gap-3 sm:gap-5">
      <a href="/" class="text-zinc-300 hover:text-emerald-400 transition-colors focus:outline-none focus:ring-2 focus:ring-emerald-500 p-1 rounded">
        Home
      </a>
      <a href="/blog" class="text-zinc-300 hover:text-emerald-400 transition-colors focus:outline-none focus:ring-2 focus:ring-emerald-500 p-1 rounded">
        Blog
      </a>
    </nav>
  </div>
</header>
