---
/**
 * Pagefind search (static index built post-`astro build`).
 * Assets under /pagefind/ are generated by the pagefind CLI.
 */
---

<link rel="stylesheet" href="/pagefind/pagefind-component-ui.css" />
<script src="/pagefind/pagefind-component-ui.js" type="module"></script>

<!-- Modal UI: trigger opens full search dialog -->
<pagefind-modal-trigger
  class="pagefind-search-trigger inline-flex items-center gap-2 rounded border border-zinc-800 bg-zinc-950 px-2.5 py-1.5 font-mono text-xs text-zinc-400 transition-colors hover:border-emerald-500 hover:text-emerald-400 focus:outline-none focus:ring-2 focus:ring-emerald-500"
  data-pagefind-ignore
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5" aria-hidden="true">
    <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
  </svg>
  <span class="hidden sm:inline">Search</span>
  <kbd class="hidden md:inline rounded border border-zinc-700 bg-zinc-900 px-1 text-[10px] text-zinc-500">⌘K</kbd>
</pagefind-modal-trigger>
<pagefind-modal data-pagefind-ignore></pagefind-modal>

<style is:global>
  /* Pagefind UI tokens — match zinc / emerald site */
  :root {
    --pagefind-ui-scale: 0.95;
    --pagefind-ui-primary: #34d399;
    --pagefind-ui-text: #e4e4e7;
    --pagefind-ui-background: #09090b;
    --pagefind-ui-border: #27272a;
    --pagefind-ui-tag: #18181b;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.25rem;
    --pagefind-ui-image-border-radius: 0.25rem;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  pagefind-modal-trigger {
    cursor: pointer;
  }
</style>
