---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Carousel from '../components/Carousel.astro';
import { getPublishedPosts, readingTimeMinutes } from '../lib/posts';
import { personSchema, websiteSchema } from '../lib/schema';

const latestPosts = (await getPublishedPosts())
  .slice(0, 3)
  .map((post) => ({
    ...post,
    readingTime: `${readingTimeMinutes(post.body)} min read`,
  }));
---

<Layout
  title="Allister Antosik - Lead SRE & AIOps Engineer Portfolio"
  schema={[websiteSchema(), personSchema]}
>
  <Header />

  <main class="py-12 flex-1 flex flex-col gap-12 w-full" data-pagefind-body>
    <!-- Hero / Role Section -->
    <section class="flex flex-col gap-4">
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-emerald-400">
        Lead SRE & AIOps Engineer
      </h1>
      <p class="text-lg text-zinc-400 max-w-3xl leading-relaxed">
        Leveraging automation, machine learning, and high-performance system engineering to build resilient, self-healing platforms.
      </p>
      <div class="flex flex-wrap gap-3 pt-1">
        <a
          href="mailto:hey@allisterantosik.com"
          class="inline-flex items-center gap-2 px-4 py-2 rounded bg-emerald-500 text-zinc-950 font-mono text-sm font-bold hover:bg-emerald-400 transition-colors focus:outline-none focus:ring-2 focus:ring-emerald-500"
        >
          Get in touch
        </a>
        <a
          href="/blog"
          class="inline-flex items-center gap-2 px-4 py-2 rounded border border-zinc-700 text-zinc-300 font-mono text-sm hover:border-emerald-500 hover:text-emerald-400 transition-colors focus:outline-none focus:ring-2 focus:ring-emerald-500"
        >
          Read the blog
        </a>
      </div>
    </section>

    <!-- Professional Background Section -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-8 border-t border-zinc-800 pt-8">
      <div>
        <h2 class="text-2xl font-bold text-zinc-200 mb-4">&gt;_ Background</h2>
        <p class="text-zinc-400 leading-relaxed mb-4">
          With extensive experience as a <strong class="text-emerald-300">senior developer</strong> and <strong class="text-emerald-300">DevOps engineer</strong>, I bridge the gap between application design and infrastructure reliability.
        </p>
        <p class="text-zinc-400 leading-relaxed">
          I design scalable CI/CD pipelines, orchestrate Kubernetes clusters, and implement advanced observability stacks using Prometheus, Grafana, and custom AIOps anomaly detection models.
        </p>
      </div>

      <!-- Design Philosophy Section -->
      <div>
        <h2 class="text-2xl font-bold text-zinc-200 mb-4">&gt;_ Design Philosophy</h2>
        <p class="text-zinc-400 leading-relaxed mb-4">
          My approach is rooted in <strong class="text-emerald-300">simplicity</strong>. I strictly adhere to the <strong class="text-emerald-300">KISS (Keep It Simple, Stupid)</strong> principle when designing both software and infrastructure architecture.
        </p>
        <p class="text-zinc-400 leading-relaxed">
          Complex architectures fail in complex ways. By keeping components decoupled, predictable, and fully automated, we ensure rapid recovery, minimal cognitive load, and maximum system availability.
        </p>
      </div>
    </section>

    <!-- Latest articles -->
    {latestPosts.length > 0 && (
      <section class="border-t border-zinc-800 pt-8 flex flex-col gap-6">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
          <div>
            <h2 class="text-2xl font-bold text-zinc-200">&gt;_ Latest Writing</h2>
            <p class="text-sm text-zinc-500 font-mono mt-1">Recent notes on reliability, tooling, and automation</p>
          </div>
          <a
            href="/blog"
            class="text-sm font-mono text-emerald-400 hover:text-emerald-300 focus:outline-none focus:ring-2 focus:ring-emerald-500 rounded p-1 self-start sm:self-auto"
          >
            View all posts →
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full">
          {latestPosts.map((post) => (
            <article class="p-6 rounded bg-zinc-900 border border-zinc-800 flex flex-col justify-between gap-4 hover:border-emerald-500 transition-colors">
              <div class="flex flex-col gap-2">
                <div class="flex justify-between items-center gap-2 text-xs text-zinc-500 font-mono">
                  <span>
                    {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                    })}
                  </span>
                  <span>{post.readingTime}</span>
                </div>
                <a href={`/blog/${post.id}`} class="group">
                  <h3 class="text-lg font-bold text-zinc-100 font-mono tracking-wide group-hover:text-emerald-400 transition-colors">
                    {post.data.title}
                  </h3>
                </a>
                <p class="text-sm text-zinc-400 leading-relaxed line-clamp-3">
                  {post.data.description}
                </p>
              </div>
              <div class="flex flex-wrap gap-2 pt-4 border-t border-zinc-800">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="px-2 py-0.5 text-xs font-mono rounded bg-zinc-950 text-emerald-400 border border-zinc-800">
                    #{tag}
                  </span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Interactive Project Showcase Section -->
    <section class="border-t border-zinc-800 pt-8 flex flex-col gap-6">
      <h2 class="text-2xl font-bold text-zinc-200">&gt;_ System Showcase</h2>
      <Carousel />
    </section>


    <!-- Dynamic Projects Section -->
    <section class="border-t border-zinc-800 pt-8 flex flex-col gap-6">
      <div class="flex justify-between items-center">
        <h2 class="text-2xl font-bold text-zinc-200">&gt;_ Open Source Projects</h2>
        <span class="text-xs text-zinc-500 bg-zinc-900 px-2 py-1 rounded border border-zinc-800 font-mono">
          HTMX Dynamic Load
        </span>
      </div>

      <div id="projects-list" hx-get="/api/projects" hx-trigger="load" class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full">
        <!-- Spinner/Skeleton Loader shown while HTMX is fetching -->
        <div class="col-span-full py-12 flex flex-col items-center justify-center gap-3 text-zinc-500 font-mono border border-dashed border-zinc-800 rounded">
          <svg class="animate-spin h-5 w-5 text-emerald-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span>Loading projects from endpoint...</span>
        </div>
      </div>
    </section>

    <script is:inline>
      (() => {
        const configureHtmx = () => {
          if (window.htmx) {
            htmx.config.timeout = 3000;
            return true;
          }
          return false;
        };
        if (!configureHtmx()) {
          const interval = setInterval(() => {
            if (configureHtmx()) clearInterval(interval);
          }, 20);
        }

        const renderFallback = () => {
          const projectsList = document.getElementById('projects-list');
          if (projectsList) {
            // Offline fallback mirrors first two live projects from /api/projects
            projectsList.innerHTML = `
              <div class="project-card p-6 rounded bg-zinc-900 border border-zinc-800 flex flex-col justify-between gap-4 hover:border-emerald-500 transition-colors">
                <div class="flex flex-col gap-2">
                  <h3 class="text-xl font-bold text-zinc-100 font-mono tracking-wide">monzo-mcp</h3>
                  <p class="text-sm text-zinc-400 leading-relaxed">Exposes Monzo's API to MCP clients (Claude Desktop, etc.) over stdio.</p>
                </div>
                <div class="flex flex-wrap items-center justify-between text-xs text-zinc-500 font-mono pt-4 border-t border-zinc-800">
                  <div class="flex gap-4">
                    <span>Language: <strong class="text-emerald-400">TypeScript</strong></span>
                  </div>
                  <span><a href="https://github.com/allistera/monzo-mcp" target="_blank" rel="noopener noreferrer" class="text-emerald-400 hover:text-emerald-300">allistera/monzo-mcp</a></span>
                </div>
              </div>
              <div class="project-card p-6 rounded bg-zinc-900 border border-zinc-800 flex flex-col justify-between gap-4 hover:border-emerald-500 transition-colors">
                <div class="flex flex-col gap-2">
                  <h3 class="text-xl font-bold text-zinc-100 font-mono tracking-wide">daily-news</h3>
                  <p class="text-sm text-zinc-400 leading-relaxed">A small Python service that assembles a daily email newsletter from a set of sources and delivers it with Resend.</p>
                </div>
                <div class="flex flex-wrap items-center justify-between text-xs text-zinc-500 font-mono pt-4 border-t border-zinc-800">
                  <div class="flex gap-4">
                    <span>Language: <strong class="text-emerald-400">Python</strong></span>
                  </div>
                  <span><a href="https://github.com/allistera/daily-news" target="_blank" rel="noopener noreferrer" class="text-emerald-400 hover:text-emerald-300">allistera/daily-news</a></span>
                </div>
              </div>
            `;
          }
        };

        let fallbackTimer;
        const isProjectsRequest = (event) => event.detail?.elt?.id === 'projects-list';
        const clearFallbackTimer = () => {
          if (fallbackTimer) {
            window.clearTimeout(fallbackTimer);
            fallbackTimer = undefined;
          }
        };
        const scheduleFallback = (event) => {
          if (!isProjectsRequest(event)) return;
          clearFallbackTimer();
          fallbackTimer = window.setTimeout(renderFallback, 3100);
        };
        const showFallback = () => {
          clearFallbackTimer();
          renderFallback();
        };

        document.addEventListener('htmx:beforeRequest', scheduleFallback);
        document.addEventListener('htmx:afterRequest', clearFallbackTimer);
        document.addEventListener('htmx:responseError', showFallback);
        document.addEventListener('htmx:sendError', showFallback);
        document.addEventListener('htmx:timeout', showFallback);
      })();
    </script>

    <!-- Contact / hire CTA -->
    <section
      class="border-t border-zinc-800 pt-8 flex flex-col md:flex-row md:items-center md:justify-between gap-6"
      data-pagefind-ignore
    >
      <div class="flex flex-col gap-2 max-w-xl">
        <h2 class="text-2xl font-bold text-zinc-200">&gt;_ Let's work together</h2>
        <p class="text-zinc-400 leading-relaxed">
          Open to SRE, platform, and reliability consulting, contract work, and interesting collaborations.
          Drop a line — I read every message.
        </p>
      </div>
      <a
        href="mailto:hey@allisterantosik.com?subject=Hello%20from%20allisterantosik.com"
        class="inline-flex shrink-0 items-center justify-center gap-2 px-5 py-3 rounded bg-emerald-500 text-zinc-950 font-mono text-sm font-bold hover:bg-emerald-400 transition-colors focus:outline-none focus:ring-2 focus:ring-emerald-500"
      >
        hey@allisterantosik.com
      </a>
    </section>
  </main>

  <Footer />
</Layout>
