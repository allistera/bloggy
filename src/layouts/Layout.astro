---
import { SEO } from 'astro-seo';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Lead SRE & AIOps Engineer Portfolio and Blog — automation, reliability, and high-performance systems.',
  image = '/logo.png',
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://allisterantosik.com').href;
const ogImage = image.startsWith('http')
  ? image
  : new URL(image, Astro.site ?? 'https://allisterantosik.com').href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      noindex={noindex}
      openGraph={{
        basic: {
          title,
          type: 'website',
          image: ogImage,
          url: canonical,
        },
        optional: {
          description,
          siteName: 'Allister Antosik',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title,
        description,
        image: ogImage,
      }}
      extend={{
        link: [
          { rel: 'icon', type: 'image/svg+xml', href: '/favicon.svg' },
          { rel: 'icon', type: 'image/png', sizes: '32x32', href: '/favicon-32.png' },
          { rel: 'apple-touch-icon', href: '/apple-touch-icon.png' },
        ],
      }}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="htmx-config" content='{"timeout": 3000}' />
    <script src="https://unpkg.com/htmx.org@1.9.12" defer></script>
  </head>
  <body class="bg-zinc-950 text-zinc-50 min-h-screen flex flex-col w-full font-mono">
    <div class="flex-1 flex flex-col w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <slot />
    </div>
    <!-- Client logs + metrics (page views, HTMX, carousel) -->
    <script src="../scripts/telemetry-init.ts"></script>
  </body>
</html>
