{
  "name": "bloggy",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && npm run pagefind",
    "pagefind": "pagefind --site dist && (test -d .vercel/output/static && cp -R dist/pagefind .vercel/output/static/ || true)",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint \"src/**/*.astro\" --max-warnings=0",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^11.0.3",
    "@sentry/astro": "^10.66.0",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.1",
    "astro-seo": "^1.1.0",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@typescript-eslint/parser": "^8.65.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "pagefind": "^1.5.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "path-to-regexp": "6.3.0"
  }
}
