# Sentry — create project "bloggy" at https://sentry.io
# Client (browser) DSN must be PUBLIC_
PUBLIC_SENTRY_DSN=

# Server DSN (can be the same as PUBLIC_SENTRY_DSN)
SENTRY_DSN=

# Source maps upload (organization auth token)
# EU org: https://de.sentry.io/settings/auth-tokens/
# Scopes: project:releases (CI token with org:ci is enough for uploads)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=bloggy
# Optional; token region is usually embedded
# SENTRY_URL=https://de.sentry.io
