# Sentry — create project "bloggy" at https://sentry.io
# Client (browser) DSN must be PUBLIC_
PUBLIC_SENTRY_DSN=

# Server DSN (can be the same as PUBLIC_SENTRY_DSN)
SENTRY_DSN=

# Source maps upload (organization auth token)
# https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=bloggy
